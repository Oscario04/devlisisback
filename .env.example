PROJECT_NAME=Devlisis API
SERVICE_NAME=devlisis-api
API_V1_PREFIX=/api
MONGODB_URI=
MONGODB_DB_NAME=devlisis
MONGODB_URI=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASSWORD=your_password
SMTP_FROM=no-reply@devlisis.com
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15

TURNSTILE_SECRET_KEY=
TURNSTILE_ENABLED=true
TURNSTILE_TIMEOUT_SECONDS=5

FRONTEND_URL=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
ENABLE_DOCS=true
CONTACT_DEDUPE_WINDOW_SECONDS=120
CONTACT_RATE_LIMIT_REQUESTS=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
LOG_LEVEL=INFO
